generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Decision {
  ALLOW
  DENY
  REQUIRE_APPROVAL
  FORCE_DRY_RUN
}

enum RiskLevel {
  low
  medium
  high
  critical
}

enum AgentSource {
  codex
  claude_code  @map("claude-code")
  mcp_proxy
  demo_harness
}

enum AdapterType {
  hook
  mcp_proxy
  simulator
}

enum Environment {
  dev
  staging
  production
}

enum GovernanceMode {
  observe
  warn
  enforce
}

enum PolicyPackScope {
  org
  workspace
  repo
}

enum SkillRunStatus {
  requested
  classified
  policy_evaluated
  dry_run_required
  dry_run_running
  dry_run_completed
  approval_required
  approval_pending
  approved
  denied
  credential_issued
  execution_queued
  executing
  completed
  failed
  rolled_back
  audited
}

enum ApprovalStatus {
  pending
  approved
  denied
  expired
}

enum ExecutionTokenStatus {
  issued
  used
  expired
  revoked
}

enum GateCheckStatus {
  pending
  running
  passed
  failed
  missing
  unknown
}

enum ActorType {
  agent
  user
  system
}

enum ConnectorStatus {
  active
  inactive
  archived
}

enum EntityStatus {
  active
  inactive
  archived
}

enum LogLevel {
  debug
  info
  warn
  error
}

enum AiRunAnalysisStatus {
  completed
  failed
  disabled
}

enum EvidenceTaskStatus {
  queued
  claimed
  running
  succeeded
  failed
  timed_out
  cancelled
}

enum EvidenceWorkerStatus {
  online
  idle
  busy
  offline
  error
}

enum SkillImportBatchStatus {
  pending
  approved
  rejected
}

enum SkillImportCandidateStatus {
  pending
  imported
  skipped
  rejected
  failed
}

model Tenant {
  id        String       @id
  name      String
  status    EntityStatus @default(active)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  workspaces             Workspace[]
  users                  User[]
  agents                 Agent[]
  skills                 Skill[]
  skillVersions          SkillVersion[]
  policies               Policy[]
  policyPacks            PolicyPack[]
  policyVersions         PolicyVersion[]
  connectors             Connector[]
  skillRuns              SkillRun[]
  gateCheckResults       GateCheckResult[]
  approvalRequests       ApprovalRequest[]
  executionTokens        ExecutionToken[]
  executionLogs          ExecutionLog[]
  dryRunResults          DryRunResult[]
  auditEvents            AuditEvent[]
  auditArtifacts         AuditArtifact[]
  skillRunAttempts       SkillRunAttempt[]
  aiRunAnalyses          AiRunAnalysis[]
  evidenceTasks          EvidenceTask[]
  evidenceArtifactCaches EvidenceArtifactCache[]
  evidenceWorkers        EvidenceWorker[]
  skillImportBatches     SkillImportBatch[]
  skillImportCandidates  SkillImportCandidate[]

  @@map("tenants")
}

model Workspace {
  id        String       @id
  tenantId  String       @map("tenant_id")
  name      String
  key       String
  status    EntityStatus @default(active)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  tenant                 Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agents                 Agent[]
  skills                 Skill[]
  skillVersions          SkillVersion[]
  policies               Policy[]
  policyPacks            PolicyPack[]
  policyVersions         PolicyVersion[]
  connectors             Connector[]
  skillRuns              SkillRun[]
  gateCheckResults       GateCheckResult[]
  approvalRequests       ApprovalRequest[]
  executionTokens        ExecutionToken[]
  executionLogs          ExecutionLog[]
  dryRunResults          DryRunResult[]
  auditEvents            AuditEvent[]
  auditArtifacts         AuditArtifact[]
  skillRunAttempts       SkillRunAttempt[]
  aiRunAnalyses          AiRunAnalysis[]
  evidenceTasks          EvidenceTask[]
  evidenceArtifactCaches EvidenceArtifactCache[]
  evidenceWorkers        EvidenceWorker[]
  skillImportBatches     SkillImportBatch[]
  skillImportCandidates  SkillImportCandidate[]

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("workspaces")
}

model User {
  id        String       @id
  tenantId  String       @map("tenant_id")
  email     String
  name      String
  role      String
  status    EntityStatus @default(active)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ownedAgents      Agent[]           @relation("AgentOwner")
  approvedRequests ApprovalRequest[] @relation("ApprovalApprovedBy")
  deniedRequests   ApprovalRequest[] @relation("ApprovalDeniedBy")

  @@unique([tenantId, email])
  @@index([tenantId, status])
  @@map("users")
}

model Agent {
  id              String       @id
  tenantId        String       @map("tenant_id")
  workspaceId     String       @map("workspace_id")
  ownerUserId     String?      @map("owner_user_id")
  externalAgentId String       @map("external_agent_id")
  source          AgentSource
  agentType       String       @map("agent_type")
  role            String
  displayName     String       @map("display_name")
  status          EntityStatus @default(active)
  metadata        Json         @default("{}")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner     User?      @relation("AgentOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  skillRuns SkillRun[]

  @@unique([tenantId, workspaceId, externalAgentId])
  @@index([tenantId, workspaceId, role])
  @@index([ownerUserId])
  @@map("agents")
}

model Skill {
  id               String       @id
  tenantId         String       @map("tenant_id")
  workspaceId      String       @map("workspace_id")
  skillId          String       @map("skill_id")
  name             String
  category         String
  description      String?
  defaultRiskLevel RiskLevel    @map("default_risk_level")
  status           EntityStatus @default(active)
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  tenant           Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace        Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  versions         SkillVersion[]
  skillRuns        SkillRun[]
  importCandidates SkillImportCandidate[]

  @@unique([tenantId, workspaceId, skillId])
  @@index([tenantId, workspaceId, category])
  @@map("skills")
}

model SkillVersion {
  id            String       @id
  tenantId      String       @map("tenant_id")
  workspaceId   String       @map("workspace_id")
  skillRecordId String       @map("skill_record_id")
  connectorId   String?      @map("connector_id")
  version       String
  config        Json         @default("{}")
  execution     Json         @default("{}")
  status        EntityStatus @default(active)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  tenant           Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace        Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  skill            Skill                  @relation(fields: [skillRecordId], references: [id], onDelete: Cascade)
  connector        Connector?             @relation(fields: [connectorId], references: [id], onDelete: SetNull)
  importCandidates SkillImportCandidate[]

  @@unique([skillRecordId, version])
  @@index([tenantId, workspaceId])
  @@index([connectorId])
  @@map("skill_versions")
}

model SkillImportBatch {
  id             String                 @id
  tenantId       String                 @map("tenant_id")
  workspaceId    String                 @map("workspace_id")
  rootDir        String                 @map("root_dir")
  status         SkillImportBatchStatus @default(pending)
  candidateCount Int                    @default(0) @map("candidate_count")
  warningCount   Int                    @default(0) @map("warning_count")
  scanConfig     Json                   @default("{}") @map("scan_config")
  warnings       Json                   @default("[]")
  requestedBy    String?                @map("requested_by")
  reviewedBy     String?                @map("reviewed_by")
  reviewComment  String?                @map("review_comment")
  reviewedAt     DateTime?              @map("reviewed_at")
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")

  tenant     Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace  Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  candidates SkillImportCandidate[]

  @@index([tenantId, workspaceId, status, createdAt])
  @@map("skill_import_batches")
}

model SkillImportCandidate {
  id                     String                     @id
  tenantId               String                     @map("tenant_id")
  workspaceId            String                     @map("workspace_id")
  batchId                String                     @map("batch_id")
  candidateId            String                     @map("candidate_id")
  skillId                String                     @map("skill_id")
  name                   String
  description            String?
  sourceType             String                     @map("source_type")
  sourcePath             String                     @map("source_path")
  relativePath           String                     @map("relative_path")
  scope                  String
  contentHash            String                     @map("content_hash")
  declaredTools          Json                       @default("[]") @map("declared_tools")
  skillType              String                     @map("skill_type")
  sideEffectLevel        String                     @map("side_effect_level")
  defaultRiskLevel       RiskLevel                  @map("default_risk_level")
  allowedRuntimes        Json                       @default("[]") @map("allowed_runtimes")
  preferredRuntimes      Json                       @default("[]") @map("preferred_runtimes")
  warnings               Json                       @default("[]")
  metadata               Json                       @default("{}")
  reviewStatus           SkillImportCandidateStatus @default(pending) @map("review_status")
  importedSkillRecordId  String?                    @map("imported_skill_record_id")
  importedSkillVersionId String?                    @map("imported_skill_version_id")
  reviewNotes            Json                       @default("{}") @map("review_notes")
  createdAt              DateTime                   @default(now()) @map("created_at")
  updatedAt              DateTime                   @updatedAt @map("updated_at")

  tenant               Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace            Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  batch                SkillImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  importedSkill        Skill?           @relation(fields: [importedSkillRecordId], references: [id], onDelete: SetNull)
  importedSkillVersion SkillVersion?    @relation(fields: [importedSkillVersionId], references: [id], onDelete: SetNull)

  @@unique([batchId, candidateId])
  @@index([tenantId, workspaceId, reviewStatus])
  @@index([tenantId, workspaceId, skillId])
  @@index([importedSkillRecordId])
  @@index([importedSkillVersionId])
  @@map("skill_import_candidates")
}

model Policy {
  id           String       @id
  tenantId     String       @map("tenant_id")
  workspaceId  String       @map("workspace_id")
  policyPackId String?      @map("policy_pack_id")
  policyId     String       @map("policy_id")
  name         String
  status       EntityStatus @default(active)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace        Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  policyPack       PolicyPack?     @relation(fields: [policyPackId], references: [id], onDelete: SetNull)
  versions         PolicyVersion[]
  matchedSkillRuns SkillRun[]      @relation("MatchedPolicyRuns")

  @@unique([tenantId, workspaceId, policyId])
  @@index([tenantId, workspaceId, status])
  @@index([policyPackId])
  @@map("policies")
}

model PolicyPack {
  id          String          @id
  tenantId    String          @map("tenant_id")
  workspaceId String          @map("workspace_id")
  packId      String          @map("pack_id")
  name        String
  scope       PolicyPackScope @default(workspace)
  source      String          @default("api")
  status      EntityStatus    @default(active)
  config      Json            @default("{}")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  policies  Policy[]

  @@unique([tenantId, workspaceId, packId])
  @@index([tenantId, workspaceId, scope, status])
  @@map("policy_packs")
}

model PolicyVersion {
  id             String       @id
  tenantId       String       @map("tenant_id")
  workspaceId    String       @map("workspace_id")
  policyRecordId String       @map("policy_record_id")
  version        String
  priority       Int
  decision       Decision
  reason         String
  definition     Json         @default("{}")
  requiredChecks Json         @default("[]") @map("required_checks")
  approvers      Json         @default("[]")
  status         EntityStatus @default(active)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  policy    Policy    @relation(fields: [policyRecordId], references: [id], onDelete: Cascade)

  @@unique([policyRecordId, version])
  @@index([tenantId, workspaceId, priority])
  @@map("policy_versions")
}

model Connector {
  id          String          @id
  tenantId    String          @map("tenant_id")
  workspaceId String          @map("workspace_id")
  connectorId String          @map("connector_id")
  name        String
  type        String
  status      ConnectorStatus @default(active)
  config      Json            @default("{}")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  skillVersions SkillVersion[]

  @@unique([tenantId, workspaceId, connectorId])
  @@index([tenantId, workspaceId, status])
  @@map("connectors")
}

model SkillRun {
  id                    String         @id
  tenantId              String         @map("tenant_id")
  workspaceId           String         @map("workspace_id")
  traceId               String         @map("trace_id")
  agentId               String?        @map("agent_id")
  skillRecordId         String?        @map("skill_record_id")
  matchedPolicyRecordId String?        @map("matched_policy_record_id")
  source                AgentSource
  adapterType           AdapterType    @map("adapter_type")
  rawAction             String         @map("raw_action")
  environment           Environment?
  mode                  GovernanceMode @default(enforce)
  decision              Decision?
  riskLevel             RiskLevel?     @map("risk_level")
  riskScore             Int?           @map("risk_score")
  riskReasons           Json           @default("[]") @map("risk_reasons")
  context               Json           @default("{}")
  requestedAt           DateTime       @default(now()) @map("requested_at")
  status                SkillRunStatus @default(requested)
  reason                String?
  resolvedSkillSnapshot Json           @default("{}") @map("resolved_skill_snapshot")
  policySnapshot        Json           @default("{}") @map("policy_snapshot")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  agent            Agent?            @relation(fields: [agentId], references: [id], onDelete: SetNull)
  skill            Skill?            @relation(fields: [skillRecordId], references: [id], onDelete: SetNull)
  matchedPolicy    Policy?           @relation("MatchedPolicyRuns", fields: [matchedPolicyRecordId], references: [id], onDelete: SetNull)
  gateCheckResults GateCheckResult[]
  approvalRequest  ApprovalRequest?
  executionTokens  ExecutionToken[]
  executionLogs    ExecutionLog[]
  dryRunResult     DryRunResult?
  skillRunAttempts SkillRunAttempt[]
  evidenceTasks    EvidenceTask[]
  auditEvents      AuditEvent[]
  auditArtifacts   AuditArtifact[]
  aiRunAnalysis    AiRunAnalysis?

  @@index([traceId])
  @@index([tenantId, createdAt])
  @@index([status])
  @@index([tenantId, workspaceId, status, createdAt])
  @@index([agentId])
  @@index([skillRecordId])
  @@index([matchedPolicyRecordId])
  @@map("skill_runs")
}

model GateCheckResult {
  id          String          @id
  tenantId    String          @map("tenant_id")
  workspaceId String          @map("workspace_id")
  skillRunId  String          @map("skill_run_id")
  checkKey    String          @map("check_key")
  label       String
  status      GateCheckStatus
  evidence    Json            @default("{}")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  skillRun      SkillRun       @relation(fields: [skillRunId], references: [id], onDelete: Cascade)
  evidenceTasks EvidenceTask[]

  @@unique([skillRunId, checkKey])
  @@index([tenantId, workspaceId, status])
  @@map("gate_check_results")
}

model ApprovalRequest {
  id                String         @id
  tenantId          String         @map("tenant_id")
  workspaceId       String         @map("workspace_id")
  skillRunId        String         @unique @map("skill_run_id")
  status            ApprovalStatus @default(pending)
  riskLevel         RiskLevel      @map("risk_level")
  approvalReadiness String         @default("blocked") @map("approval_readiness")
  missingChecks     Json           @default("[]") @map("missing_checks")
  requiredApprovers Json           @default("[]") @map("required_approvers")
  evidence          Json           @default("{}")
  requestedBy       String?        @map("requested_by")
  approvedByUserId  String?        @map("approved_by_user_id")
  deniedByUserId    String?        @map("denied_by_user_id")
  approvedAt        DateTime?      @map("approved_at")
  deniedAt          DateTime?      @map("denied_at")
  expiresAt         DateTime?      @map("expires_at")
  comment           String?
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  skillRun        SkillRun         @relation(fields: [skillRunId], references: [id], onDelete: Cascade)
  approvedByUser  User?            @relation("ApprovalApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  deniedByUser    User?            @relation("ApprovalDeniedBy", fields: [deniedByUserId], references: [id], onDelete: SetNull)
  executionTokens ExecutionToken[]
  evidenceTasks   EvidenceTask[]

  @@index([status, createdAt])
  @@index([skillRunId])
  @@index([approvedByUserId])
  @@index([deniedByUserId])
  @@map("approval_requests")
}

model ExecutionToken {
  id                String               @id
  tenantId          String               @map("tenant_id")
  workspaceId       String               @map("workspace_id")
  skillRunId        String               @map("skill_run_id")
  approvalRequestId String?              @map("approval_request_id")
  tokenHash         String               @map("token_hash")
  scopes            Json                 @default("[]")
  environment       Environment?
  status            ExecutionTokenStatus @default(issued)
  expiresAt         DateTime             @map("expires_at")
  usedAt            DateTime?            @map("used_at")
  revokedAt         DateTime?            @map("revoked_at")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace       Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  skillRun        SkillRun          @relation(fields: [skillRunId], references: [id], onDelete: Cascade)
  approvalRequest ApprovalRequest?  @relation(fields: [approvalRequestId], references: [id], onDelete: SetNull)
  attempts        SkillRunAttempt[]

  @@unique([skillRunId, tokenHash])
  @@index([skillRunId])
  @@index([approvalRequestId])
  @@index([status, expiresAt])
  @@map("execution_tokens")
}

model ExecutionLog {
  id          String   @id
  tenantId    String   @map("tenant_id")
  workspaceId String   @map("workspace_id")
  skillRunId  String   @map("skill_run_id")
  sequence    Int
  level       LogLevel
  message     String
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  skillRun  SkillRun  @relation(fields: [skillRunId], references: [id], onDelete: Cascade)

  @@unique([skillRunId, sequence])
  @@index([skillRunId, sequence])
  @@index([tenantId, workspaceId, createdAt])
  @@map("execution_logs")
}

model AiRunAnalysis {
  id                 String              @id
  tenantId           String              @map("tenant_id")
  workspaceId        String              @map("workspace_id")
  skillRunId         String              @unique @map("skill_run_id")
  traceId            String              @map("trace_id")
  summary            String
  severity           String
  riskNotes          Json                @default("[]") @map("risk_notes")
  missingEvidence    Json                @default("[]") @map("missing_evidence")
  suggestedActions   Json                @default("[]") @map("suggested_actions")
  failureCause       String?             @map("failure_cause")
  approverNotes      String?             @map("approver_notes")
  model              String
  provider           String?
  inputTokens        Int                 @default(0) @map("input_tokens")
  outputTokens       Int                 @default(0) @map("output_tokens")
  totalTokens        Int                 @default(0) @map("total_tokens")
  estimatedCostCents Int                 @default(0) @map("estimated_cost_cents")
  status             AiRunAnalysisStatus @default(completed)
  error              String?
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  skillRun  SkillRun  @relation(fields: [skillRunId], references: [id], onDelete: Cascade)

  @@index([traceId])
  @@index([tenantId, workspaceId, createdAt])
  @@index([status, createdAt])
  @@map("ai_run_analyses")
}

model EvidenceTask {
  id                String             @id
  tenantId          String             @map("tenant_id")
  workspaceId       String             @map("workspace_id")
  skillRunId        String             @map("skill_run_id")
  approvalRequestId String?            @map("approval_request_id")
  gateCheckResultId String             @map("gate_check_result_id")
  traceId           String             @map("trace_id")
  checkKey          String             @map("check_key")
  label             String
  evidenceSkillId   String             @map("evidence_skill_id")
  targetSkillId     String             @map("target_skill_id")
  runtime           String
  status            EvidenceTaskStatus @default(queued)
  priority          Int                @default(0)
  attempt           Int                @default(1)
  claimedByAgentId  String?            @map("claimed_by_agent_id")
  leaseExpiresAt    DateTime?          @map("lease_expires_at")
  input             Json               @default("{}")
  result            Json               @default("{}")
  error             Json               @default("{}")
  createdBy         String?            @map("created_by")
  claimedAt         DateTime?          @map("claimed_at")
  startedAt         DateTime?          @map("started_at")
  completedAt       DateTime?          @map("completed_at")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  skillRun        SkillRun         @relation(fields: [skillRunId], references: [id], onDelete: Cascade)
  approvalRequest ApprovalRequest? @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)
  gateCheckResult GateCheckResult  @relation(fields: [gateCheckResultId], references: [id], onDelete: Cascade)

  @@unique([gateCheckResultId, attempt])
  @@index([tenantId, workspaceId, status, createdAt])
  @@index([tenantId, workspaceId, status, priority, createdAt])
  @@index([skillRunId, status])
  @@index([approvalRequestId])
  @@index([gateCheckResultId])
  @@index([status, leaseExpiresAt])
  @@map("evidence_tasks")
}

model EvidenceWorker {
  id              String               @id
  tenantId        String               @map("tenant_id")
  workspaceId     String               @map("workspace_id")
  agentId         String               @map("agent_id")
  runtime         String
  driver          String
  status          EvidenceWorkerStatus @default(online)
  currentTaskId   String?              @map("current_task_id")
  currentCheckKey String?              @map("current_check_key")
  processedCount  Int                  @default(0) @map("processed_count")
  failedCount     Int                  @default(0) @map("failed_count")
  metadata        Json                 @default("{}")
  lastHeartbeatAt DateTime             @default(now()) @map("last_heartbeat_at")
  startedAt       DateTime             @default(now()) @map("started_at")
  stoppedAt       DateTime?            @map("stopped_at")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([tenantId, workspaceId, agentId])
  @@index([tenantId, workspaceId, status, lastHeartbeatAt])
  @@index([currentTaskId])
  @@map("evidence_workers")
}

model EvidenceArtifactCache {
  id                 String          @id
  tenantId           String          @map("tenant_id")
  workspaceId        String          @map("workspace_id")
  checkKey           String          @map("check_key")
  targetIdentityHash String          @map("target_identity_hash")
  repo               String?
  commitSha          String?         @map("commit_sha")
  environment        Environment?
  status             GateCheckStatus
  reason             String
  evidence           Json            @default("{}")
  confidence         Float           @default(0)
  sourceTaskId       String?         @map("source_task_id")
  collectedAt        DateTime        @map("collected_at")
  expiresAt          DateTime        @map("expires_at")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([tenantId, workspaceId, checkKey, targetIdentityHash])
  @@index([tenantId, workspaceId, expiresAt])
  @@index([repo, commitSha, environment])
  @@map("evidence_artifact_cache")
}

model DryRunResult {
  id          String   @id
  tenantId    String   @map("tenant_id")
  workspaceId String   @map("workspace_id")
  skillRunId  String   @unique @map("skill_run_id")
  status      String
  summary     String
  result      Json     @default("{}")
  artifacts   Json     @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  skillRun  SkillRun  @relation(fields: [skillRunId], references: [id], onDelete: Cascade)

  @@index([tenantId, workspaceId, createdAt])
  @@map("dry_run_results")
}

model SkillRunAttempt {
  id                String    @id
  tenantId          String    @map("tenant_id")
  workspaceId       String    @map("workspace_id")
  skillRunId        String    @map("skill_run_id")
  executionTokenId  String?   @map("execution_token_id")
  idempotencyKey    String    @map("idempotency_key")
  status            String
  result            Json      @default("{}")
  error             Json      @default("{}")
  claimedByRunnerId String?   @map("claimed_by_runner_id")
  leaseExpiresAt    DateTime? @map("lease_expires_at")
  heartbeatAt       DateTime? @map("heartbeat_at")
  startedAt         DateTime? @map("started_at")
  completedAt       DateTime? @map("completed_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  skillRun       SkillRun        @relation(fields: [skillRunId], references: [id], onDelete: Cascade)
  executionToken ExecutionToken? @relation(fields: [executionTokenId], references: [id], onDelete: SetNull)

  @@unique([skillRunId, idempotencyKey])
  @@index([skillRunId, idempotencyKey])
  @@index([executionTokenId])
  @@map("skill_run_attempts")
}

model AuditEvent {
  id          String    @id
  tenantId    String    @map("tenant_id")
  workspaceId String    @map("workspace_id")
  skillRunId  String?   @map("skill_run_id")
  traceId     String    @map("trace_id")
  eventType   String    @map("event_type")
  actorType   ActorType @map("actor_type")
  actorId     String?   @map("actor_id")
  sequence    Int?
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now()) @map("created_at")

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  skillRun  SkillRun?       @relation(fields: [skillRunId], references: [id], onDelete: SetNull)
  artifacts AuditArtifact[]

  @@index([traceId, createdAt])
  @@index([skillRunId, createdAt])
  @@index([tenantId, createdAt])
  @@map("audit_events")
}

model AuditArtifact {
  id           String   @id
  tenantId     String   @map("tenant_id")
  workspaceId  String   @map("workspace_id")
  auditEventId String?  @map("audit_event_id")
  skillRunId   String?  @map("skill_run_id")
  artifactId   String   @map("artifact_id")
  type         String
  uri          String?
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  auditEvent AuditEvent? @relation(fields: [auditEventId], references: [id], onDelete: Cascade)
  skillRun   SkillRun?   @relation(fields: [skillRunId], references: [id], onDelete: SetNull)

  @@index([auditEventId])
  @@index([skillRunId])
  @@index([tenantId, workspaceId, createdAt])
  @@map("audit_artifacts")
}
