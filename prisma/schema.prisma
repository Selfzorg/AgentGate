generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Decision {
  ALLOW
  DENY
  REQUIRE_APPROVAL
  FORCE_DRY_RUN
}

enum RiskLevel {
  low
  medium
  high
  critical
}

enum AgentSource {
  codex
  claude_code @map("claude-code")
  mcp_proxy
  demo_harness
}

enum AdapterType {
  hook
  mcp_proxy
  simulator
}

enum Environment {
  dev
  staging
  production
}

enum GovernanceMode {
  observe
  enforce
}

enum SkillRunStatus {
  requested
  classified
  policy_evaluated
  dry_run_required
  dry_run_running
  dry_run_completed
  approval_required
  approval_pending
  approved
  denied
  credential_issued
  execution_queued
  executing
  completed
  failed
  rolled_back
  audited
}

enum ApprovalStatus {
  pending
  approved
  denied
  expired
}

enum ExecutionTokenStatus {
  issued
  used
  expired
  revoked
}

enum GateCheckStatus {
  passed
  failed
  missing
  unknown
}

enum ActorType {
  agent
  user
  system
}

enum ConnectorStatus {
  active
  inactive
  archived
}

enum EntityStatus {
  active
  inactive
  archived
}

enum LogLevel {
  debug
  info
  warn
  error
}

model Tenant {
  id        String       @id
  name      String
  status    EntityStatus @default(active)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  workspaces       Workspace[]
  users            User[]
  agents           Agent[]
  skills           Skill[]
  skillVersions    SkillVersion[]
  policies         Policy[]
  policyVersions   PolicyVersion[]
  connectors       Connector[]
  skillRuns        SkillRun[]
  gateCheckResults GateCheckResult[]
  approvalRequests ApprovalRequest[]
  executionTokens  ExecutionToken[]
  executionLogs    ExecutionLog[]
  dryRunResults    DryRunResult[]
  auditEvents      AuditEvent[]
  auditArtifacts   AuditArtifact[]
  skillRunAttempts SkillRunAttempt[]

  @@map("tenants")
}

model Workspace {
  id        String       @id
  tenantId  String       @map("tenant_id")
  name      String
  key       String
  status    EntityStatus @default(active)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agents           Agent[]
  skills           Skill[]
  skillVersions    SkillVersion[]
  policies         Policy[]
  policyVersions   PolicyVersion[]
  connectors       Connector[]
  skillRuns        SkillRun[]
  gateCheckResults GateCheckResult[]
  approvalRequests ApprovalRequest[]
  executionTokens  ExecutionToken[]
  executionLogs    ExecutionLog[]
  dryRunResults    DryRunResult[]
  auditEvents      AuditEvent[]
  auditArtifacts   AuditArtifact[]
  skillRunAttempts SkillRunAttempt[]

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("workspaces")
}

model User {
  id        String       @id
  tenantId  String       @map("tenant_id")
  email     String
  name      String
  role      String
  status    EntityStatus @default(active)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ownedAgents      Agent[]           @relation("AgentOwner")
  approvedRequests ApprovalRequest[] @relation("ApprovalApprovedBy")
  deniedRequests   ApprovalRequest[] @relation("ApprovalDeniedBy")

  @@unique([tenantId, email])
  @@index([tenantId, status])
  @@map("users")
}

model Agent {
  id              String       @id
  tenantId        String       @map("tenant_id")
  workspaceId     String       @map("workspace_id")
  ownerUserId     String?      @map("owner_user_id")
  externalAgentId String       @map("external_agent_id")
  source          AgentSource
  agentType       String       @map("agent_type")
  role            String
  displayName     String       @map("display_name")
  status          EntityStatus @default(active)
  metadata        Json         @default("{}")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner     User?      @relation("AgentOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  skillRuns SkillRun[]

  @@unique([tenantId, workspaceId, externalAgentId])
  @@index([tenantId, workspaceId, role])
  @@index([ownerUserId])
  @@map("agents")
}

model Skill {
  id               String       @id
  tenantId         String       @map("tenant_id")
  workspaceId      String       @map("workspace_id")
  skillId          String       @map("skill_id")
  name             String
  category         String
  description      String?
  defaultRiskLevel RiskLevel    @map("default_risk_level")
  status           EntityStatus @default(active)
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  versions  SkillVersion[]
  skillRuns SkillRun[]

  @@unique([tenantId, workspaceId, skillId])
  @@index([tenantId, workspaceId, category])
  @@map("skills")
}

model SkillVersion {
  id            String       @id
  tenantId      String       @map("tenant_id")
  workspaceId   String       @map("workspace_id")
  skillRecordId String       @map("skill_record_id")
  connectorId   String?      @map("connector_id")
  version       String
  config        Json         @default("{}")
  execution     Json         @default("{}")
  status        EntityStatus @default(active)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  skill     Skill      @relation(fields: [skillRecordId], references: [id], onDelete: Cascade)
  connector Connector? @relation(fields: [connectorId], references: [id], onDelete: SetNull)

  @@unique([skillRecordId, version])
  @@index([tenantId, workspaceId])
  @@index([connectorId])
  @@map("skill_versions")
}

model Policy {
  id          String       @id
  tenantId    String       @map("tenant_id")
  workspaceId String       @map("workspace_id")
  policyId    String       @map("policy_id")
  name        String
  status      EntityStatus @default(active)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace        Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  versions         PolicyVersion[]
  matchedSkillRuns SkillRun[]      @relation("MatchedPolicyRuns")

  @@unique([tenantId, workspaceId, policyId])
  @@index([tenantId, workspaceId, status])
  @@map("policies")
}

model PolicyVersion {
  id             String       @id
  tenantId       String       @map("tenant_id")
  workspaceId    String       @map("workspace_id")
  policyRecordId String       @map("policy_record_id")
  version        String
  priority       Int
  decision       Decision
  reason         String
  definition     Json         @default("{}")
  requiredChecks Json         @default("[]") @map("required_checks")
  approvers      Json         @default("[]")
  status         EntityStatus @default(active)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  policy    Policy    @relation(fields: [policyRecordId], references: [id], onDelete: Cascade)

  @@unique([policyRecordId, version])
  @@index([tenantId, workspaceId, priority])
  @@map("policy_versions")
}

model Connector {
  id          String          @id
  tenantId    String          @map("tenant_id")
  workspaceId String          @map("workspace_id")
  connectorId String          @map("connector_id")
  name        String
  type        String
  status      ConnectorStatus @default(active)
  config      Json            @default("{}")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  skillVersions SkillVersion[]

  @@unique([tenantId, workspaceId, connectorId])
  @@index([tenantId, workspaceId, status])
  @@map("connectors")
}

model SkillRun {
  id                    String          @id
  tenantId              String          @map("tenant_id")
  workspaceId           String          @map("workspace_id")
  traceId               String          @map("trace_id")
  agentId               String?         @map("agent_id")
  skillRecordId         String?         @map("skill_record_id")
  matchedPolicyRecordId String?         @map("matched_policy_record_id")
  source                AgentSource
  adapterType           AdapterType     @map("adapter_type")
  rawAction             String          @map("raw_action")
  environment           Environment?
  mode                  GovernanceMode  @default(enforce)
  decision              Decision?
  riskLevel             RiskLevel?      @map("risk_level")
  riskScore             Int?            @map("risk_score")
  riskReasons           Json            @default("[]") @map("risk_reasons")
  context               Json            @default("{}")
  requestedAt           DateTime        @default(now()) @map("requested_at")
  status                SkillRunStatus  @default(requested)
  reason                String?
  resolvedSkillSnapshot Json            @default("{}") @map("resolved_skill_snapshot")
  policySnapshot        Json            @default("{}") @map("policy_snapshot")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  agent             Agent?             @relation(fields: [agentId], references: [id], onDelete: SetNull)
  skill             Skill?             @relation(fields: [skillRecordId], references: [id], onDelete: SetNull)
  matchedPolicy     Policy?            @relation("MatchedPolicyRuns", fields: [matchedPolicyRecordId], references: [id], onDelete: SetNull)
  gateCheckResults  GateCheckResult[]
  approvalRequest   ApprovalRequest?
  executionTokens   ExecutionToken[]
  executionLogs     ExecutionLog[]
  dryRunResult      DryRunResult?
  skillRunAttempts  SkillRunAttempt[]
  auditEvents       AuditEvent[]
  auditArtifacts    AuditArtifact[]

  @@index([traceId])
  @@index([tenantId, createdAt])
  @@index([status])
  @@index([tenantId, workspaceId, status, createdAt])
  @@index([agentId])
  @@index([skillRecordId])
  @@index([matchedPolicyRecordId])
  @@map("skill_runs")
}

model GateCheckResult {
  id          String          @id
  tenantId    String          @map("tenant_id")
  workspaceId String          @map("workspace_id")
  skillRunId  String          @map("skill_run_id")
  checkKey    String          @map("check_key")
  label       String
  status      GateCheckStatus
  evidence    Json            @default("{}")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  skillRun  SkillRun  @relation(fields: [skillRunId], references: [id], onDelete: Cascade)

  @@unique([skillRunId, checkKey])
  @@index([tenantId, workspaceId, status])
  @@map("gate_check_results")
}

model ApprovalRequest {
  id               String         @id
  tenantId         String         @map("tenant_id")
  workspaceId      String         @map("workspace_id")
  skillRunId       String         @unique @map("skill_run_id")
  status           ApprovalStatus @default(pending)
  riskLevel        RiskLevel      @map("risk_level")
  approvalReadiness String        @default("blocked") @map("approval_readiness")
  missingChecks    Json           @default("[]") @map("missing_checks")
  requiredApprovers Json          @default("[]") @map("required_approvers")
  evidence         Json           @default("{}")
  requestedBy      String?        @map("requested_by")
  approvedByUserId String?        @map("approved_by_user_id")
  deniedByUserId   String?        @map("denied_by_user_id")
  approvedAt       DateTime?      @map("approved_at")
  deniedAt         DateTime?      @map("denied_at")
  expiresAt        DateTime?      @map("expires_at")
  comment          String?
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  skillRun       SkillRun         @relation(fields: [skillRunId], references: [id], onDelete: Cascade)
  approvedByUser User?            @relation("ApprovalApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  deniedByUser   User?            @relation("ApprovalDeniedBy", fields: [deniedByUserId], references: [id], onDelete: SetNull)
  executionTokens ExecutionToken[]

  @@index([status, createdAt])
  @@index([skillRunId])
  @@index([approvedByUserId])
  @@index([deniedByUserId])
  @@map("approval_requests")
}

model ExecutionToken {
  id                String               @id
  tenantId          String               @map("tenant_id")
  workspaceId       String               @map("workspace_id")
  skillRunId        String               @map("skill_run_id")
  approvalRequestId String?              @map("approval_request_id")
  tokenHash         String               @map("token_hash")
  scopes            Json                 @default("[]")
  environment       Environment?
  status            ExecutionTokenStatus @default(issued)
  expiresAt         DateTime             @map("expires_at")
  usedAt            DateTime?            @map("used_at")
  revokedAt         DateTime?            @map("revoked_at")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  skillRun        SkillRun         @relation(fields: [skillRunId], references: [id], onDelete: Cascade)
  approvalRequest ApprovalRequest? @relation(fields: [approvalRequestId], references: [id], onDelete: SetNull)
  attempts        SkillRunAttempt[]

  @@unique([skillRunId, tokenHash])
  @@index([skillRunId])
  @@index([approvalRequestId])
  @@index([status, expiresAt])
  @@map("execution_tokens")
}

model ExecutionLog {
  id          String   @id
  tenantId    String   @map("tenant_id")
  workspaceId String   @map("workspace_id")
  skillRunId  String   @map("skill_run_id")
  sequence    Int
  level       LogLevel
  message     String
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  skillRun  SkillRun  @relation(fields: [skillRunId], references: [id], onDelete: Cascade)

  @@unique([skillRunId, sequence])
  @@index([skillRunId, sequence])
  @@index([tenantId, workspaceId, createdAt])
  @@map("execution_logs")
}

model DryRunResult {
  id          String   @id
  tenantId    String   @map("tenant_id")
  workspaceId String   @map("workspace_id")
  skillRunId  String   @unique @map("skill_run_id")
  status      String
  summary     String
  result      Json     @default("{}")
  artifacts   Json     @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  skillRun  SkillRun  @relation(fields: [skillRunId], references: [id], onDelete: Cascade)

  @@index([tenantId, workspaceId, createdAt])
  @@map("dry_run_results")
}

model SkillRunAttempt {
  id               String    @id
  tenantId         String    @map("tenant_id")
  workspaceId      String    @map("workspace_id")
  skillRunId       String    @map("skill_run_id")
  executionTokenId String?   @map("execution_token_id")
  idempotencyKey   String    @map("idempotency_key")
  status           String
  result           Json      @default("{}")
  error            Json      @default("{}")
  startedAt        DateTime? @map("started_at")
  completedAt      DateTime? @map("completed_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  skillRun       SkillRun        @relation(fields: [skillRunId], references: [id], onDelete: Cascade)
  executionToken ExecutionToken? @relation(fields: [executionTokenId], references: [id], onDelete: SetNull)

  @@unique([skillRunId, idempotencyKey])
  @@index([skillRunId, idempotencyKey])
  @@index([executionTokenId])
  @@map("skill_run_attempts")
}

model AuditEvent {
  id          String    @id
  tenantId    String    @map("tenant_id")
  workspaceId String    @map("workspace_id")
  skillRunId  String?   @map("skill_run_id")
  traceId     String    @map("trace_id")
  eventType   String    @map("event_type")
  actorType   ActorType @map("actor_type")
  actorId     String?   @map("actor_id")
  sequence    Int?
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now()) @map("created_at")

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  skillRun  SkillRun?       @relation(fields: [skillRunId], references: [id], onDelete: SetNull)
  artifacts AuditArtifact[]

  @@index([traceId, createdAt])
  @@index([skillRunId, createdAt])
  @@index([tenantId, createdAt])
  @@map("audit_events")
}

model AuditArtifact {
  id           String   @id
  tenantId     String   @map("tenant_id")
  workspaceId  String   @map("workspace_id")
  auditEventId String?  @map("audit_event_id")
  skillRunId   String?  @map("skill_run_id")
  artifactId   String   @map("artifact_id")
  type         String
  uri          String?
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  auditEvent AuditEvent? @relation(fields: [auditEventId], references: [id], onDelete: Cascade)
  skillRun   SkillRun?   @relation(fields: [skillRunId], references: [id], onDelete: SetNull)

  @@index([auditEventId])
  @@index([skillRunId])
  @@index([tenantId, workspaceId, createdAt])
  @@map("audit_artifacts")
}
