{
  "name": "agentgate",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "agentgate": "./bin/agentgate.js"
  },
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "agentgate": "tsx apps/agentgate-cli/src/index.ts",
    "dev": "pnpm --parallel --filter @agentgate/api-server --filter @agentgate/web-dashboard dev",
    "lint": "eslint .",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "tsx scripts/run-tests-isolated.mjs",
    "test:ai": "tsx scripts/run-tests-isolated.mjs tests/ai-run-intelligence.test.ts",
    "test:demo": "tsx scripts/run-tests-isolated.mjs tests/phase3.test.ts tests/demo-readiness-qa.test.ts",
    "test:governance": "tsx scripts/run-tests-isolated.mjs tests/phase3.test.ts tests/risk-scanner.test.ts tests/audit-integrity.test.ts tests/runner-hardening.test.ts",
    "test:integrations": "tsx scripts/run-tests-isolated.mjs tests/integrations.test.ts",
    "test:raw": "vitest run",
    "verify": "pnpm lint && pnpm typecheck && pnpm test",
    "mcp:build": "pnpm --filter @agentgate/mcp-proxy build",
    "mcp:start": "pnpm --filter @agentgate/mcp-proxy start",
    "evidence:process": "tsx scripts/evidence-worker.ts --once",
    "evidence:worker": "tsx scripts/evidence-worker.ts",
    "evidence:claude-worker": "tsx scripts/claude-evidence-worker.ts",
    "claude:agentgate": "node scripts/claude-agentgate.mjs",
    "codex:install-hook": "node scripts/install-codex-hook.mjs",
    "demo:bootstrap": "node scripts/demo-bootstrap.mjs",
    "demo:local": "node scripts/demo-local.mjs",
    "demo:setup": "pnpm postgres:start && pnpm db:deploy && pnpm db:seed",
    "demo:verify": "node scripts/demo-verify.mjs",
    "demo:reset": "node scripts/demo-reset.mjs",
    "demo:log": "node scripts/demo-log-tail.mjs",
    "demo:run": "tsx scripts/run-demo-scenario.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --name init",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "postgres:init": "node scripts/local-postgres.mjs init",
    "postgres:start": "node scripts/local-postgres.mjs start",
    "postgres:stop": "node scripts/local-postgres.mjs stop"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@agentgate/ai-provider": "workspace:*",
    "@agentgate/cli": "workspace:*",
    "@agentgate/config-loader": "workspace:*",
    "@agentgate/policy-engine": "workspace:*",
    "@agentgate/risk-engine": "workspace:*",
    "@agentgate/skill-registry": "workspace:*",
    "@agentgate/skill-resolver": "workspace:*",
    "@electric-sql/pglite": "0.4.6",
    "@electric-sql/pglite-socket": "0.1.6",
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.9.0",
    "eslint": "^9.15.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vitest": "^2.1.5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
