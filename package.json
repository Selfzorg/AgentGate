{
  "name": "agentgate",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @agentgate/api-server --filter @agentgate/web-dashboard dev",
    "lint": "eslint .",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --name init",
    "db:seed": "prisma db seed",
    "postgres:init": "scripts/local-postgres.sh init",
    "postgres:start": "scripts/local-postgres.sh start",
    "postgres:stop": "scripts/local-postgres.sh stop"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@agentgate/config-loader": "workspace:*",
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.9.0",
    "eslint": "^9.15.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vitest": "^2.1.5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
