{
  "name": "agentgate",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @agentgate/api-server --filter @agentgate/web-dashboard dev",
    "lint": "eslint .",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "vitest run",
    "test:ai": "vitest run tests/ai-run-intelligence.test.ts",
    "test:demo": "vitest run tests/phase3.test.ts tests/demo-readiness-qa.test.ts",
    "test:governance": "vitest run tests/phase3.test.ts tests/risk-scanner.test.ts tests/audit-integrity.test.ts tests/runner-hardening.test.ts",
    "test:integrations": "vitest run tests/integrations.test.ts",
    "verify": "pnpm lint && pnpm typecheck && pnpm test",
    "mcp:build": "pnpm --filter @agentgate/mcp-proxy build",
    "mcp:start": "pnpm --filter @agentgate/mcp-proxy start",
    "evidence:process": "tsx scripts/evidence-worker.ts --once",
    "evidence:worker": "tsx scripts/evidence-worker.ts",
    "evidence:claude-worker": "tsx scripts/claude-evidence-worker.ts",
    "claude:agentgate": "node scripts/claude-agentgate.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --name init",
    "db:seed": "prisma db seed",
    "postgres:init": "scripts/local-postgres.sh init",
    "postgres:start": "scripts/local-postgres.sh start",
    "postgres:stop": "scripts/local-postgres.sh stop"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@agentgate/config-loader": "workspace:*",
    "@agentgate/ai-provider": "workspace:*",
    "@agentgate/policy-engine": "workspace:*",
    "@agentgate/risk-engine": "workspace:*",
    "@agentgate/skill-registry": "workspace:*",
    "@agentgate/skill-resolver": "workspace:*",
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.9.0",
    "eslint": "^9.15.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vitest": "^2.1.5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
